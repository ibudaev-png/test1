<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Battery Charge</title>
  <style>
    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family: system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      color:#fff;
      background:#0b1220;
    }

    .page{
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
      position:relative;
      overflow:hidden;
      text-align:center;
    }

    .bg{
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.25), rgba(0,0,0,.55)),
        url("https://asset.gecdesigns.com/img/background-templates/abstract-navy-red-background-design-sr17012401-1705501852665-cover.webp");
      background-size:cover;
      background-position:center;
      transform:scale(1.02);
      z-index:0;
    }

    .card{
      position:relative;
      z-index:1;
      width:min(520px, 92vw);
      padding:24px 18px 20px;
      border-radius:18px;
      background:rgba(8,12,24,.35);
      backdrop-filter: blur(8px);
      border:1px solid rgba(255,255,255,.12);
      box-shadow: 0 12px 30px rgba(0,0,0,.35);
      display:flex;
      flex-direction:column;
      gap:14px;
      align-items:center;
    }

    .battery-wrap{
      width:min(240px, 62vw);
      aspect-ratio: 1 / 1;
      display:grid;
      place-items:center;
    }

    svg{
      width:100%;
      height:100%;
      display:block;
      filter: drop-shadow(0 10px 18px rgba(0,0,0,.35));
    }

    .percent{font-size:18px; letter-spacing:.3px; opacity:.95;}
    .hint{font-size:13px; opacity:.75; margin-top:-6px;}

    .btn{
      width:min(320px, 90%);
      height:50px;
      border:0;
      border-radius:14px;
      font-size:16px;
      font-weight:700;
      cursor:pointer;
      color:#0b1220;
      background: linear-gradient(90deg, rgba(255,255,255,.95), rgba(255,255,255,.8));
      box-shadow: 0 10px 18px rgba(0,0,0,.25);
      transition: transform .12s ease, opacity .12s ease;
    }
    .btn:active{transform:scale(.98)}
    .btn[disabled]{opacity:.55; cursor:not-allowed}

    @media (max-width:420px){
      .card{padding:18px 14px}
      .percent{font-size:16px}
    }
  </style>
</head>
<body>
  <main class="page">
    <div class="bg" aria-hidden="true"></div>

    <section class="card" aria-label="Battery charging widget">
      <div class="battery-wrap">
        <!-- SVG battery: fill is clipped INSIDE the outline -->
        <svg viewBox="0 0 200 260" role="img" aria-label="Battery">
          <defs>
            <!-- Inner area (what we allow to be filled) -->
            <clipPath id="innerClip">
              <!-- inside the outline (leave padding for stroke) -->
              <rect x="34" y="58" width="132" height="176" rx="22"></rect>
            </clipPath>

            <!-- Fill gradient -->
            <linearGradient id="fillGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="rgba(0,255,170,0.95)"/>
              <stop offset="1" stop-color="rgba(0,255,170,0.25)"/>
            </linearGradient>
          </defs>

          <!-- Fill layer (animated rect), clipped to inner area -->
          <g clip-path="url(#innerClip)">
            <!-- full inner area background (optional, makes "empty" look) -->
            <rect x="34" y="58" width="132" height="176" rx="22" fill="rgba(255,255,255,0.02)"></rect>

            <!-- This rect will grow upward -->
            <rect id="fillRect" x="34" y="234" width="132" height="0" fill="url(#fillGrad)"></rect>
          </g>

          <!-- Battery outline -->
          <rect x="26" y="50" width="148" height="190" rx="28"
                fill="none" stroke="#000" stroke-width="14" />

          <!-- Top cap -->
          <path d="M70 18 H130
                   Q138 18 138 26
                   V40
                   H62
                   V26
                   Q62 18 70 18 Z"
                fill="none" stroke="#000" stroke-width="14" stroke-linejoin="round"/>

          <!-- Lightning bolt (kept black like your icon) -->
          <path d="M114 88 L84 144 H108 L86 198 L140 124 H112 Z"
                fill="#000"/>
        </svg>
      </div>

      <div class="percent" id="counter">0 / 130</div>
      <div class="hint" id="status">Tap Start to begin charging.</div>

      <button class="btn" id="startBtn">Start</button>
    </section>
  </main>

  <script>
    const MAX = 130;
    const DURATION_MS = 7000;

    const fillRect = document.getElementById('fillRect');
    const counterEl = document.getElementById('counter');
    const statusEl = document.getElementById('status');
    const btn = document.getElementById('startBtn');

    // inner area geometry must match clipPath rect:
    const INNER_Y = 58;
    const INNER_H = 176;

    let animId = null;

    function setProgress(value){
      const v = Math.max(0, Math.min(MAX, value));
      const ratio = v / MAX;

      const h = Math.round(INNER_H * ratio);
      const y = INNER_Y + (INNER_H - h);

      fillRect.setAttribute('y', String(y));
      fillRect.setAttribute('height', String(h));

      counterEl.textContent = `${v} / ${MAX}`;
    }

    function start(){
      btn.textContent = "Start";
      btn.disabled = true;
      statusEl.textContent = "Charging…";

      const startTime = performance.now();
      setProgress(0);

      if (animId) cancelAnimationFrame(animId);

      function tick(now){
        const t = Math.min(1, (now - startTime) / DURATION_MS);
        setProgress(Math.round(t * MAX));

        if (t < 1){
          animId = requestAnimationFrame(tick);
        } else {
          statusEl.textContent = "Charged to 130.";
          btn.disabled = false;
        }
      }

      requestAnimationFrame(tick);
    }

    btn.addEventListener('click', start);
    setProgress(0);
  </script>
</body>
</html>
